{
  "manifest_version": 3,
  "name": "Ice Storm",
  "version": "1.0.3",
  "description": "Summon a dancer to glide across the page, bust a move, and slide off-screen. Click the toolbar icon to trigger an Ice Storm — a whole crew at once.",
  "icons": {
    "48": "icons/ice.svg",
    "96": "icons/ice.svg"
  },
  "action": {
    "default_title": "Ice Storm",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/ice.svg",
      "96": "icons/ice.svg"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": ["alarms", "storage", "tabs"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/ice-dancer.webp"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{0eafbbed-9f86-429f-9a1d-f051eb486464}",
      "strict_min_version": "140.0",
      "update_url": "https://raw.githubusercontent.com/CaseyMargell/ice-storm/main/updates.json",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
